{
  "_comentario": "Copie para selecao_modelos.private.json e ajuste conforme seu ambiente.",
  "input": {
    "dataset_path": "../data/experimentos/ground_truth.csv",
    "text_column": "<COD_VARIAVEL>",
    "class_columns": [
      "Contexto (Baixa Prod)",
      "Contexto (Baixo Valor)",
      "Contexto (Alto Prod)",
      "Contexto (Alto Valor)",
      "Contexto (Perda de Prod.)"
    ]
  },
  "split": {
    "knowledge_frac": 0.7,
    "random_state": 42
  },
  "evaluation": {
    "thresholds": [0.55, 0.6, 0.65, 0.7, 0.75, 0.8, 0.85, 0.9],
    "batch_size": 64,
    "plot_roc": true,
    "plot_metrics": true
  },
  "models": {
    "llama_embed_nemotron_8b": {
      "enabled": true,
      "label": "llama-embed-nemotron-8b",
      "type": "sentence_transformer",
      "model_name": "nvidia/llama-embed-nemotron-8b",
      "encode_method": "encode_query",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      },
      "sentence_transformer_kwargs": {
        "trust_remote_code": true,
        "model_kwargs": {
          "attn_implementation": "eager",
          "torch_dtype": "bfloat16"
        },
        "tokenizer_kwargs": {
          "padding_side": "left"
        }
      }
    },
    "msmarco_distilbert_cos_v5": {
      "enabled": true,
      "label": "msmarco-distilbert-cos-v5",
      "type": "sentence_transformer",
      "model_name": "sentence-transformers/msmarco-distilbert-cos-v5",
      "encode_method": "encode",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      }
    },
    "bge_m3": {
      "enabled": true,
      "label": "bge-m3",
      "type": "sentence_transformer",
      "model_name": "BAAI/bge-m3",
      "encode_method": "encode",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      }
    },
    "cnmoro_portuguese_en_bge_m3": {
      "enabled": true,
      "label": "cnmoro/portuguese-en-bge-m3",
      "type": "sentence_transformer",
      "model_name": "cnmoro/portuguese-en-bge-m3",
      "encode_method": "encode",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      }
    },
    "all_minilm_l6_v2": {
      "enabled": true,
      "label": "all-MiniLM-L6-v2",
      "type": "sentence_transformer",
      "model_name": "sentence-transformers/all-MiniLM-L6-v2",
      "encode_method": "encode",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      }
    },
    "multilingual_e5_large_instruct": {
      "enabled": true,
      "label": "multilingual-e5-large-instruct",
      "type": "sentence_transformer",
      "model_name": "intfloat/multilingual-e5-large-instruct",
      "encode_method": "encode",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      }
    },
    "qwen3_embedding_8b": {
      "enabled": true,
      "label": "Qwen3-Embedding-8B",
      "type": "sentence_transformer",
      "model_name": "Qwen/Qwen3-Embedding-8B",
      "encode_method": "encode",
      "kwargs": {
        "convert_to_numpy": true,
        "batch_size": 64
      }
    },
    "bertimbau": {
      "enabled": true,
      "label": "BERTIMBAU",
      "type": "bertimbau",
      "model_name": "neuralmind/bert-base-portuguese-cased",
      "kwargs": {
        "max_length": 512,
        "batch_size": 256
      }
    }
  },
  "model_execution_order": [
    "llama_embed_nemotron_8b",
    "msmarco_distilbert_cos_v5",
    "bge_m3",
    "cnmoro_portuguese_en_bge_m3",
    "all_minilm_l6_v2",
    "multilingual_e5_large_instruct",
    "qwen3_embedding_8b",
    "bertimbau"
  ],
  "knowledge_base": {
    "model_key": "all_minilm_l6_v2",
    "index_output_path": "../data/generated/faiss_observation_index.bin",
    "reference_output_path": "../data/generated/faiss_observation_reference.csv"
  },
  "reports": {
    "metrics_output_path": "../data/generated/selecao_modelos_metrics.json"
  }
}
